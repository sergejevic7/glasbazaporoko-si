# See https://help.github.com/articles/ignoring-files/

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
/.next/
/out/

# Production builds (non-Next)
/build
/dist

# Testing
/coverage

# Environment & secrets (never commit real keys)
.env
.env.*
!.env.example

# Vercel (local CLI links deployment to account — keep private)
.vercel

# Debug / package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Certificates / keys
*.pem

# TypeScript (build caches only — commit next-env.d.ts)
*.tsbuildinfo

# IDE / editors (keep team-shared .vscode settings if you add them explicitly)
.idea/
*.swp
*.swo

# Turborepo (if you add monorepo later)
.turbo

# Optional: local scratch / downloads from tooling
site-home.html
